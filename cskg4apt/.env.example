CUSTOM_API_KEY=

# Anthropic (Direct API)
ANTHROPIC_API_KEY=

# Tongyi Qwen (DashScope / 通义千问)
DASHSCOPE_API_KEY=

# ZhipuAI (GLM-4 / 智谱AI)
ZHIPUAI_API_KEY=

# DeepSeek (深度求索)
DEEPSEEK_API_KEY=

# Baidu ERNIE (Qianfan / 百度文心)
QIANFAN_API_KEY=

# iFlytek Spark (讯飞星火)
SPARK_API_KEY=

# Neo4j (optional, for CSKG4APT mode)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=cskg4apt
